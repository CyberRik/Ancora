# Copy to .env for local (non-Docker) development. Docker Compose sets these itself.

# --- API Gateway ---
ANCORA_ENVIRONMENT=development
ANCORA_LOG_LEVEL=INFO
ANCORA_LOG_JSON=true
ANCORA_DATABASE_URL=postgresql+asyncpg://ancora:ancora@localhost:5432/ancora
ANCORA_CORS_ORIGINS=["http://localhost:3000"]

# --- Dashboard ---
NEXT_PUBLIC_API_URL=http://localhost:8080
